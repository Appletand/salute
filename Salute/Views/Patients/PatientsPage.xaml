<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Salute.Views.Patients.PatientsPage"
             Title="Pacientes">

	<Grid RowDefinitions="Auto,*,Auto" Padding="15" RowSpacing="10">

		<Grid Grid.Row="0" ColumnDefinitions="*,Auto">
			<Label Text="Pacientes" FontSize="22" FontAttributes="Bold" VerticalOptions="Center"/>
			<Button Grid.Column="1" Text="+ Novo" Clicked="OnAddPatientClicked"
                    BackgroundColor="#5B4FCF" TextColor="White" CornerRadius="10" Padding="12,8"/>
		</Grid>

		<CollectionView Grid.Row="1"
                        ItemsSource="{Binding Patients}"
                        EmptyView="Nenhum paciente cadastrado.">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Grid ColumnDefinitions="*,Auto" Padding="5,8">
						<VerticalStackLayout Grid.Column="0" Spacing="3">
							<Label FontSize="15" FontAttributes="Bold"
                                   Text="{Binding FirstName}"/>
							<Label FontSize="12" TextColor="Gray"
                                   Text="{Binding DateOfBirth, StringFormat='{0:dd/MM/yyyy}'}"/>
						</VerticalStackLayout>
						<Button Grid.Column="1" Text="Ver"
                                BackgroundColor="#5B4FCF" TextColor="White"
                                CornerRadius="8" WidthRequest="55"
                                VerticalOptions="Center"
                                CommandParameter="{Binding .}"
                                Clicked="OnViewPatientClicked"/>
					</Grid>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

		<Label Grid.Row="2"
               Text="{Binding Patients.Count, StringFormat='{0} paciente(s)'}"
               HorizontalOptions="Center" TextColor="Gray" FontSize="13"/>
	</Grid>
</ContentPage>