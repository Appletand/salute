<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Salute.Views.Anamnesis.AnamnesisPage"
             Title="Anamnese">

	<Grid RowDefinitions="Auto,Auto,*,Auto" Padding="15" RowSpacing="10">

		<!-- Seleção de paciente -->
		<Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
			<Picker Title="Selecione o paciente"
                    ItemsSource="{Binding Patients}"
                    ItemDisplayBinding="{Binding FirstName}"
                    SelectedIndexChanged="OnPatientSelected"/>
			<Button Grid.Column="1"
                    Text="Limpar"
                    Command="{Binding ClearCommand}"
                    BackgroundColor="Orange"
                    TextColor="White"
                    CornerRadius="10"
                    WidthRequest="80"/>
		</Grid>

		<!-- Status -->
		<Label Grid.Row="1"
               Text="{Binding StatusMessage}"
               HorizontalOptions="Center"
               FontSize="13"
               TextColor="Gray"/>

		<!-- Formulário -->
		<ScrollView Grid.Row="2">
			<VerticalStackLayout Spacing="12">

				<!-- Queixa Principal -->
				<Frame CornerRadius="12" Padding="15" HasShadow="True">
					<VerticalStackLayout Spacing="10">
						<Label Text="QUEIXA PRINCIPAL" FontAttributes="Bold" FontSize="14"/>
						<Entry Placeholder="Motivo da consulta"
                               Text="{Binding Anamnesis.MainComplaint}"/>
						<Entry Placeholder="Sintomas associados"
                               Text="{Binding Anamnesis.Symptoms}"/>
						<Entry Placeholder="Há quanto tempo?"
                               Text="{Binding Anamnesis.SymptomsDuration}"/>
						<Picker Title="Nível de dor (1-10)"
                                SelectedItem="{Binding Anamnesis.PainLevel}">
							<Picker.Items>
								<x:String>1 - Muito leve</x:String>
								<x:String>2 - Leve</x:String>
								<x:String>3 - Moderado</x:String>
								<x:String>4 - Forte</x:String>
								<x:String>5 - Muito forte</x:String>
								<x:String>6 - Insuportável</x:String>
							</Picker.Items>
						</Picker>
					</VerticalStackLayout>
				</Frame>

				<!-- Histórico Médico -->
				<Frame CornerRadius="12" Padding="15" HasShadow="True">
					<VerticalStackLayout Spacing="10">
						<Label Text="HISTÓRICO MÉDICO" FontAttributes="Bold" FontSize="14"/>
						<Entry Placeholder="Doenças pré-existentes"
                               Text="{Binding Anamnesis.MedicalConditions}"/>
						<Entry Placeholder="Alergias"
                               Text="{Binding Anamnesis.Allergies}"/>
						<Entry Placeholder="Medicamentos em uso"
                               Text="{Binding Anamnesis.CurrentMedications}"/>
						<Entry Placeholder="Cirurgias anteriores"
                               Text="{Binding Anamnesis.PreviousSurgeries}"/>
						<Entry Placeholder="Internações"
                               Text="{Binding Anamnesis.Hospitalizations}"/>
					</VerticalStackLayout>
				</Frame>

				<!-- Histórico Odontológico -->
				<Frame CornerRadius="12" Padding="15" HasShadow="True">
					<VerticalStackLayout Spacing="10">
						<Label Text="HISTÓRICO ODONTOLÓGICO" FontAttributes="Bold" FontSize="14"/>
						<Entry Placeholder="Tratamentos anteriores"
                               Text="{Binding Anamnesis.PreviousTreatments}"/>
						<Entry Placeholder="Última visita ao dentista"
                               Text="{Binding Anamnesis.LastDentalVisit}"/>
						<Entry Placeholder="Hábitos de higiene"
                               Text="{Binding Anamnesis.DentalHygiene}"/>
						<Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="5">
							<CheckBox IsChecked="{Binding Anamnesis.UsesDentalProsthesis}"/>
							<Label Grid.Column="1" Text="Usa prótese?" VerticalOptions="Center"/>
							<CheckBox Grid.Column="2" IsChecked="{Binding Anamnesis.HasBleedingGums}"/>
							<Label Grid.Column="3" Text="Sangramento gengival?" VerticalOptions="Center"/>
						</Grid>
					</VerticalStackLayout>
				</Frame>

				<!-- Hábitos -->
				<Frame CornerRadius="12" Padding="15" HasShadow="True">
					<VerticalStackLayout Spacing="10">
						<Label Text="HÁBITOS" FontAttributes="Bold" FontSize="14"/>
						<Entry Placeholder="Tabagismo" Text="{Binding Anamnesis.Smoking}"/>
						<Entry Placeholder="Consumo de álcool" Text="{Binding Anamnesis.Alcohol}"/>
						<Entry Placeholder="Alimentação" Text="{Binding Anamnesis.Diet}"/>
						<Entry Placeholder="Atividade física" Text="{Binding Anamnesis.PhysicalActivity}"/>
					</VerticalStackLayout>
				</Frame>

				<!-- Sinais Vitais -->
				<Frame CornerRadius="12" Padding="15" HasShadow="True">
					<VerticalStackLayout Spacing="10">
						<Label Text="SINAIS VITAIS" FontAttributes="Bold" FontSize="14"/>
						<Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="5">
							<Entry Placeholder="Sistólica"
                                   Text="{Binding Anamnesis.BloodPressureSystolic}"
                                   Keyboard="Numeric"/>
							<Label Grid.Column="1" Text="/" VerticalOptions="Center" FontSize="18"/>
							<Entry Grid.Column="2" Placeholder="Diastólica"
                                   Text="{Binding Anamnesis.BloodPressureDiastolic}"
                                   Keyboard="Numeric"/>
						</Grid>
						<Grid ColumnDefinitions="*,*" ColumnSpacing="10">
							<Entry Placeholder="Freq. cardíaca (bpm)"
                                   Text="{Binding Anamnesis.HeartRate}"
                                   Keyboard="Numeric"/>
							<Entry Grid.Column="1" Placeholder="Temperatura (°C)"
                                   Text="{Binding Anamnesis.Temperature}"
                                   Keyboard="Numeric"/>
						</Grid>
					</VerticalStackLayout>
				</Frame>

				<!-- Observações -->
				<Frame CornerRadius="12" Padding="15" HasShadow="True">
					<VerticalStackLayout Spacing="10">
						<Label Text="OBSERVAÇÕES" FontAttributes="Bold" FontSize="14"/>
						<Editor Placeholder="Observações adicionais..."
                                Text="{Binding Anamnesis.Observations}"
                                HeightRequest="100"/>
					</VerticalStackLayout>
				</Frame>

				<!-- Histórico -->
				<Frame CornerRadius="12" Padding="15" HasShadow="True">
					<VerticalStackLayout Spacing="8">
						<Label Text="HISTÓRICO DE ANAMNESES" FontAttributes="Bold" FontSize="14"/>
						<ListView ItemsSource="{Binding AnamnesisHistory}"
                                  HeightRequest="150"
                                  HasUnevenRows="True">
							<ListView.ItemTemplate>
								<DataTemplate>
									<TextCell
                                        Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                        Detail="{Binding MainComplaint, StringFormat='Queixa: {0}'}"/>
								</DataTemplate>
							</ListView.ItemTemplate>
						</ListView>
					</VerticalStackLayout>
				</Frame>

				<ActivityIndicator IsVisible="{Binding IsLoading}"
                                   IsRunning="{Binding IsLoading}"
                                   Color="#5B4FCF"
                                   HorizontalOptions="Center"/>
			</VerticalStackLayout>
		</ScrollView>

		<!-- Botões de ação -->
		<Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="10">
			<Button Text="Gerar com IA"
                    BackgroundColor="#7B2FBE"
                    TextColor="White"
                    CornerRadius="10"
                    IsEnabled="False"/>
			<Button Grid.Column="1"
                    Text="Salvar Anamnese"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="10"/>
		</Grid>
	</Grid>
</ContentPage>