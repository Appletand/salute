<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Salute.ViewModels"
             x:Class="Salute.Views.Patients.PatientDetailPage"
             x:DataType="vm:PatientDetailViewModel"
             Title="Detalhes do Paciente"
             BackgroundColor="#F5F7FA">

	<Grid>

		<ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#0D6E6E"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           ZIndex="10" />

		<CollectionView ItemsSource="{Binding Timeline}"
                        Margin="16,0">

			<CollectionView.Header>
				<VerticalStackLayout Spacing="16" Padding="0,16,0,8">

					<!-- Avatar + Nome -->
					<Border BackgroundColor="White"
                            StrokeShape="RoundRectangle 16"
                            Stroke="#E5E7EB"
                            Padding="20">
						<Border.Shadow>
							<Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
						</Border.Shadow>
						<VerticalStackLayout Spacing="12" HorizontalOptions="Center">
							<Border WidthRequest="72"
                                    HeightRequest="72"
                                    BackgroundColor="#E8F4F4"
                                    StrokeShape="RoundRectangle 36"
                                    Stroke="Transparent"
                                    HorizontalOptions="Center">
								<Label Text="{Binding Initials}"
                                       TextColor="#0D6E6E"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
							</Border>
							<Label FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#1A1A2E"
                                   HorizontalOptions="Center">
								<Label.FormattedText>
									<FormattedString>
										<Span Text="{Binding Patient.FirstName}" />
										<Span Text=" " />
										<Span Text="{Binding Patient.LastName}" />
									</FormattedString>
								</Label.FormattedText>
							</Label>
						</VerticalStackLayout>
					</Border>

					<!-- Dados sensíveis -->
					<Border BackgroundColor="White"
                            StrokeShape="RoundRectangle 16"
                            Stroke="#E5E7EB"
                            Padding="20">
						<Border.Shadow>
							<Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
						</Border.Shadow>
						<VerticalStackLayout Spacing="14">

							<Button Text="{Binding SensitiveToggleText}"
                                    Command="{Binding ToggleSensitiveCommand}"
                                    BackgroundColor="#E8F4F4"
                                    TextColor="#0D6E6E"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    CornerRadius="8"
                                    HeightRequest="38" />

							<!-- Telefone -->
							<Grid ColumnDefinitions="90,*" ColumnSpacing="12">
								<Label Grid.Column="0"
                                       Text="Telefone"
                                       TextColor="#6B7280"
                                       FontSize="13"
                                       VerticalOptions="Center" />
								<VerticalStackLayout Grid.Column="1">
									<Label Text="{Binding Patient.Phone}"
                                           TextColor="#1A1A2E"
                                           FontSize="14">
										<Label.Triggers>
											<DataTrigger TargetType="Label"
                                                         Binding="{Binding IsSensitiveVisible}"
                                                         Value="False">
												<Setter Property="IsVisible" Value="False" />
											</DataTrigger>
										</Label.Triggers>
									</Label>
									<Label Text="•••••••"
                                           TextColor="#1A1A2E"
                                           FontSize="14">
										<Label.Triggers>
											<DataTrigger TargetType="Label"
                                                         Binding="{Binding IsSensitiveVisible}"
                                                         Value="True">
												<Setter Property="IsVisible" Value="False" />
											</DataTrigger>
										</Label.Triggers>
									</Label>
								</VerticalStackLayout>
							</Grid>

							<!-- E-mail -->
							<Grid ColumnDefinitions="90,*" ColumnSpacing="12">
								<Label Grid.Column="0"
                                       Text="E-mail"
                                       TextColor="#6B7280"
                                       FontSize="13"
                                       VerticalOptions="Center" />
								<VerticalStackLayout Grid.Column="1">
									<Label Text="{Binding Patient.Email}"
                                           TextColor="#1A1A2E"
                                           FontSize="14">
										<Label.Triggers>
											<DataTrigger TargetType="Label"
                                                         Binding="{Binding IsSensitiveVisible}"
                                                         Value="False">
												<Setter Property="IsVisible" Value="False" />
											</DataTrigger>
										</Label.Triggers>
									</Label>
									<Label Text="•••••••"
                                           TextColor="#1A1A2E"
                                           FontSize="14">
										<Label.Triggers>
											<DataTrigger TargetType="Label"
                                                         Binding="{Binding IsSensitiveVisible}"
                                                         Value="True">
												<Setter Property="IsVisible" Value="False" />
											</DataTrigger>
										</Label.Triggers>
									</Label>
								</VerticalStackLayout>
							</Grid>

							<!-- Nascimento -->
							<Grid ColumnDefinitions="90,*" ColumnSpacing="12">
								<Label Grid.Column="0"
                                       Text="Nascimento"
                                       TextColor="#6B7280"
                                       FontSize="13"
                                       VerticalOptions="Center" />
								<VerticalStackLayout Grid.Column="1">
									<Label Text="{Binding Patient.DateOfBirth, StringFormat='{0:dd/MM/yyyy}'}"
                                           TextColor="#1A1A2E"
                                           FontSize="14">
										<Label.Triggers>
											<DataTrigger TargetType="Label"
                                                         Binding="{Binding IsSensitiveVisible}"
                                                         Value="False">
												<Setter Property="IsVisible" Value="False" />
											</DataTrigger>
										</Label.Triggers>
									</Label>
									<Label Text="••/••/••••"
                                           TextColor="#1A1A2E"
                                           FontSize="14">
										<Label.Triggers>
											<DataTrigger TargetType="Label"
                                                         Binding="{Binding IsSensitiveVisible}"
                                                         Value="True">
												<Setter Property="IsVisible" Value="False" />
											</DataTrigger>
										</Label.Triggers>
									</Label>
								</VerticalStackLayout>
							</Grid>

						</VerticalStackLayout>
					</Border>

					<Label Text="Histórico"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="#1A1A2E"
                           Margin="4,0" />

				</VerticalStackLayout>
			</CollectionView.Header>

			<CollectionView.EmptyView>
				<Label Text="Nenhum registro no histórico."
                       TextColor="#9CA3AF"
                       HorizontalOptions="Center"
                       FontSize="14"
                       Margin="0,16" />
			</CollectionView.EmptyView>

			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Border Margin="0,0,0,12"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 12"
                            Stroke="#E5E7EB"
                            Padding="16">
						<Border.Shadow>
							<Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
						</Border.Shadow>
						<Grid ColumnDefinitions="4,*" ColumnSpacing="12">
							<BoxView Grid.Column="0"
                                     BackgroundColor="#0D6E6E"
                                     CornerRadius="2"
                                     VerticalOptions="Fill" />
							<VerticalStackLayout Grid.Column="1" Spacing="6">
								<Grid ColumnDefinitions="*,Auto">
									<Label Grid.Column="0"
                                           Text="{Binding Title}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#1A1A2E" />
									<Label Grid.Column="1"
                                           Text="{Binding Date, StringFormat='{0:dd/MM/yyyy}'}"
                                           FontSize="12"
                                           TextColor="#9CA3AF"
                                           VerticalOptions="Center" />
								</Grid>
								<Label Text="{Binding Summary}"
                                       FontSize="13"
                                       TextColor="#6B7280"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
								<Border BackgroundColor="#E8F4F4"
                                        StrokeShape="RoundRectangle 4"
                                        Stroke="Transparent"
                                        Padding="6,2"
                                        HorizontalOptions="Start">
									<Label Text="{Binding TypeLabel}"
                                           FontSize="11"
                                           TextColor="#0D6E6E"
                                           FontAttributes="Bold" />
								</Border>
							</VerticalStackLayout>
						</Grid>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>

			<CollectionView.Footer>
				<BoxView HeightRequest="24" Color="Transparent" />
			</CollectionView.Footer>

		</CollectionView>
	</Grid>
</ContentPage>