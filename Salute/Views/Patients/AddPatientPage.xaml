<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Salute.Views.Patients.AddPatientPage"
             Title="Novo Paciente">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">

            <Label Text="Cadastrar Paciente"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <Frame CornerRadius="12" Padding="15" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="DADOS PESSOAIS" FontAttributes="Bold" FontSize="13" TextColor="Gray"/>

                    <Entry Placeholder="Nome *"
                           Text="{Binding FirstName}"/>
                    <Entry Placeholder="Sobrenome *"
                           Text="{Binding LastName}"/>
                    <DatePicker Date="{Binding DateOfBirth}"
                                Format="dd/MM/yyyy"
                                MaximumDate="{x:Static sys:DateTime.Today}"
                                xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="15" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="CONTATO" FontAttributes="Bold" FontSize="13" TextColor="Gray"/>
                    <Entry Placeholder="Telefone"
                           Text="{Binding Phone}"
                           Keyboard="Telephone"/>
                    <Entry Placeholder="E-mail"
                           Text="{Binding Email}"
                           Keyboard="Email"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="{Binding StatusMessage}"
                   HorizontalOptions="Center"
                   TextColor="#C0392B"
                   FontSize="13"/>

            <Button Text="Salvar Paciente"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#5B4FCF"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="50"
                    IsEnabled="{Binding IsLoading, Converter={x:StaticResource InverseBoolConverter}}"/>

            <ActivityIndicator IsVisible="{Binding IsLoading}"
                               IsRunning="{Binding IsLoading}"
                               Color="#5B4FCF"
                               HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>