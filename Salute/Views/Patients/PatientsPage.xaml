<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Salute.ViewModels"
             x:Class="Salute.Views.Patients.PatientsPage"
             x:DataType="vm:PatientsViewModel"
             Title="Pacientes"
             BackgroundColor="#F5F7FA">

	<ContentPage.ToolbarItems>
		<ToolbarItem Text="＋" Command="{Binding AddPatientCommand}" />
	</ContentPage.ToolbarItems>

	<Grid RowDefinitions="Auto,*,Auto">

		<ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#0D6E6E"
                           HeightRequest="32"
                           Margin="0,12,0,4" />

		<CollectionView x:Name="PatientsCollectionView"
                        Grid.Row="1"
                        ItemsSource="{Binding Patients}"
                        SelectionMode="Single"
                        SelectionChanged="OnPatientSelected"
                        Margin="16,4,16,0">

			<CollectionView.EmptyView>
				<VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8"
                                     Margin="0,80,0,0">
					<Label Text="Nenhum paciente cadastrado."
                           TextColor="#6B7280"
                           HorizontalOptions="Center"
                           FontSize="15" />
					<Label Text="Toque em + para adicionar."
                           TextColor="#9CA3AF"
                           HorizontalOptions="Center"
                           FontSize="13" />
				</VerticalStackLayout>
			</CollectionView.EmptyView>

			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Border Margin="0,0,0,12"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 12"
                            Stroke="#E5E7EB"
                            Padding="16">
						<Border.Shadow>
							<Shadow Brush="Black"
                                    Offset="0,2"
                                    Radius="8"
                                    Opacity="0.06" />
						</Border.Shadow>
						<Grid ColumnDefinitions="60,*" ColumnSpacing="12">

							<Border Grid.Column="0"
                                    WidthRequest="48"
                                    HeightRequest="48"
                                    BackgroundColor="#E8F4F4"
                                    StrokeShape="RoundRectangle 24"
                                    Stroke="Transparent"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start">
								<Label Text="{Binding Initials}"
                                       TextColor="#0D6E6E"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
							</Border>

							<VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
								<Label FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#1A1A2E">
									<Label.FormattedText>
										<FormattedString>
											<Span Text="{Binding FirstName}" />
											<Span Text=" " />
											<Span Text="{Binding LastName}" />
										</FormattedString>
									</Label.FormattedText>
								</Label>
								<Label Text="{Binding Phone}"
                                       TextColor="#6B7280"
                                       FontSize="13" />
								<Label Text="{Binding Email}"
                                       TextColor="#9CA3AF"
                                       FontSize="12" />
							</VerticalStackLayout>

						</Grid>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

		<Label Grid.Row="2"
               Text="{Binding StatusMessage}"
               TextColor="#6B7280"
               HorizontalOptions="Center"
               FontSize="13"
               Margin="0,8,0,16">
			<Label.Triggers>
				<DataTrigger TargetType="Label"
                             Binding="{Binding StatusMessage}"
                             Value="">
					<Setter Property="IsVisible" Value="False" />
				</DataTrigger>
			</Label.Triggers>
		</Label>

	</Grid>
</ContentPage>