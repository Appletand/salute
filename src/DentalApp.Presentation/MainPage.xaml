<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DentalApp.Presentation.MainPage"
             Title="DentalApp">
    <VerticalStackLayout Spacing="25" Padding="30,0" VerticalOptions="Center">
        <Label Text="Bem-vindo ao DentalApp" FontSize="32" HorizontalOptions="Center" />
        <Button Text="Pacientes" Clicked="OnPatientsClicked" />
        <Button Text="Agendamentos" Clicked="OnAppointmentsClicked" />
        <Button Text="Exportar para Obsidian" Clicked="OnExportClicked" />
    </VerticalStackLayout>
</ContentPage>