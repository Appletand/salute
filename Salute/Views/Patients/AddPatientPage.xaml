<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Salute.ViewModels"
             x:Class="Salute.Views.Patients.AddPatientPage"
             x:DataType="vm:AddPatientViewModel"
             Title="Novo Paciente"
             BackgroundColor="#F5F7FA">

	<ScrollView>
		<VerticalStackLayout Padding="24" Spacing="16">

			<Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 16"
                    Stroke="#E5E7EB"
                    Padding="20">
				<Border.Shadow>
					<Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
				</Border.Shadow>
				<VerticalStackLayout Spacing="16">

					<Label Text="Dados do Paciente"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="#1A1A2E" />

					<VerticalStackLayout Spacing="4">
						<Label Text="Nome *" TextColor="#374151" FontSize="13" />
						<Border BackgroundColor="#F9FAFB"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#D1D5DB"
                                Padding="12,0">
							<Entry Text="{Binding FirstName}"
                                   Placeholder="Nome"
                                   PlaceholderColor="#9CA3AF"
                                   TextColor="#1A1A2E"
                                   FontSize="15" />
						</Border>
					</VerticalStackLayout>

					<VerticalStackLayout Spacing="4">
						<Label Text="Sobrenome *" TextColor="#374151" FontSize="13" />
						<Border BackgroundColor="#F9FAFB"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#D1D5DB"
                                Padding="12,0">
							<Entry Text="{Binding LastName}"
                                   Placeholder="Sobrenome"
                                   PlaceholderColor="#9CA3AF"
                                   TextColor="#1A1A2E"
                                   FontSize="15" />
						</Border>
					</VerticalStackLayout>

					<VerticalStackLayout Spacing="4">
						<Label Text="Telefone" TextColor="#374151" FontSize="13" />
						<Border BackgroundColor="#F9FAFB"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#D1D5DB"
                                Padding="12,0">
							<Entry Text="{Binding Phone}"
                                   Placeholder="(00) 00000-0000"
                                   PlaceholderColor="#9CA3AF"
                                   TextColor="#1A1A2E"
                                   FontSize="15"
                                   Keyboard="Telephone" />
						</Border>
					</VerticalStackLayout>

					<VerticalStackLayout Spacing="4">
						<Label Text="E-mail" TextColor="#374151" FontSize="13" />
						<Border BackgroundColor="#F9FAFB"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#D1D5DB"
                                Padding="12,0">
							<Entry Text="{Binding Email}"
                                   Placeholder="email@exemplo.com"
                                   PlaceholderColor="#9CA3AF"
                                   TextColor="#1A1A2E"
                                   FontSize="15"
                                   Keyboard="Email" />
						</Border>
					</VerticalStackLayout>

					<VerticalStackLayout Spacing="4">
						<Label Text="Data de Nascimento" TextColor="#374151" FontSize="13" />
						<Border BackgroundColor="#F9FAFB"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#D1D5DB"
                                Padding="12,8">
							<DatePicker Date="{Binding DateOfBirth}"
                                        TextColor="#1A1A2E"
                                        FontSize="15"
                                        Format="dd/MM/yyyy" />
						</Border>
					</VerticalStackLayout>

				</VerticalStackLayout>
			</Border>

			<Label Text="{Binding StatusMessage}"
                   TextColor="#374151"
                   FontSize="13"
                   HorizontalOptions="Center">
				<Label.Triggers>
					<DataTrigger TargetType="Label"
                                 Binding="{Binding StatusMessage}"
                                 Value="">
						<Setter Property="IsVisible" Value="False" />
					</DataTrigger>
				</Label.Triggers>
			</Label>

			<ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="#0D6E6E"
                               HorizontalOptions="Center" />

			<Button Text="Salvar Paciente"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#0D6E6E"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    CornerRadius="12" />

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>